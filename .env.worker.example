# =============================================================================
# Variables del worker de procesamiento de CVs
# Copia este archivo a .env.worker y completa con tus credenciales.
# =============================================================================

# --- Supabase (service role, NO anon) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Proveedores de IA ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Knobs operacionales (todos opcionales) ---

# Cuántos items procesar en paralelo. Default 1 (serial).
# Sube solo si la cola se acumula con frecuencia entre orgs distintas.
WORKER_CONCURRENCY=1

# Tiempo de espera cuando la cola está vacía o todas las orgs están pausadas.
WORKER_IDLE_MS=30000

# Pausa tras un error de RPC/red antes de reintentar.
WORKER_ERROR_MS=6000

# Si un item lleva más de N minutos en `processing`, se considera abandonado
# por un procesador caído y se libera automáticamente.
WORKER_LOCK_TIMEOUT_MIN=10

# Puerto del endpoint /health (Docker HEALTHCHECK, k8s liveness).
HEALTH_PORT=8080
